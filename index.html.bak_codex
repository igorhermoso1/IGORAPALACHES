      { text:'Acercarte con la linterna a investigar.', outcome:'bad', delta:{sanity:-25,health:-20}, msg:'La figura desaparece antes de que llegues. Las huellas en el barro no pertenecen a ningún animal que reconozcas.', requires:'linterna' },
      { text:'Observar en completo silencio. Sin moverte.', outcome:'neutral', delta:{sanity:-15}, msg:'Con el primer indicio de amanecer, desaparece. No sabías que podías contener la respiración tanto tiempo.' },
      { text:'Hacer ruido fuerte para espantarla.', outcome:'bad', delta:{sanity:-20,health:-10}, msg:'Giras la cabeza un momento. Cuando vuelves a mirar, la figura está más cerca. No la viste moverse.' },
      { text:'Buscar referencia en el diario hallado.', outcome:'good', delta:{sanity:8}, msg:'"Watcher figures — observan, no atacan mientras no te acerques. Ignorar, no mirar fijamente, esperar."', requires:'diario' },
