      { text:'Consultar la nota sobre fauna anómala.', outcome:'good', delta:{sanity:8}, msg:'"Not deer. No hagas contacto visual sostenido. Retrocede lento, sin correr. No demuestres miedo."', requires:'nota_vieja' },
      { text:'Intentar ahuyentarlo con ruido fuerte.', outcome:'bad', delta:{sanity:-22,health:-12}, msg:'El ciervo no se asusta. Se gira despacio. Su boca se abre más de lo anatómicamente posible.' },
    ]
  },
  {
    id:'voice_name', minNight:3,
    title:'Tu nombre en el bosque',
    text:'Una voz. Perfectamente familiar. Tu nombre pronunciado con la entonación exacta de alguien cercano. Viene de entre los árboles, a unos veinte metros. No hay nadie en estos Apalaches que te conozca.',
    choices:[
      { text:'"¿Quién eres? ¿Qué quieres?"', outcome:'bad', delta:{sanity:-28,health:-15}, msg:'La voz responde con tu nombre. Y luego con el nombre de alguien que no has mencionado a nadie.' },
