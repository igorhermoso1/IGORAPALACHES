      { text:'Revisar si hay algún objeto "anómalo" en el inventario.', outcome:'good', delta:{sanity:10}, msg:'La piedra con grabados cherokee. Cuando la acercas al suelo, el rascado se detiene en seco.', requires:'piedra_rara' },
