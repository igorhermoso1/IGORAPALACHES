      { text:'Cruzar directamente a través de ella.', outcome:'bad', delta:{sanity:-45,health:-20}, msg:'Hay un momento de oscuridad absoluta. Cuando ves de nuevo, estás en el suelo. No sabes cuánto tiempo has estado inconsciente.' },
    ]
