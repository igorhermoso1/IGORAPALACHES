<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APALACHES: 30 NOCHES</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=Inconsolata:wght@300;400;500;700&family=Cinzel:wght@400;600;700&display=swap');

:root {
  --bg: #0a0805;
  --bg2: #110e0a;
  --bg3: #1a1510;
  --bg4: #221c14;
  --surface: #2a2318;
  --surface2: #342c1e;
  --amber: #c8922a;
  --amber-dim: #7a5818;
  --amber-bright: #e8b85a;
  --red: #8b2020;
  --red-bright: #c43030;
  --green: #2a5c3a;
  --green-bright: #4a9c5a;
  --text: #d4c8a8;
  --text-dim: #8a7c5c;
  --text-bright: #f0e8c8;
  --border: #3a3020;
  --border2: #4a4028;
  --fog: rgba(10,8,5,0.85);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Inconsolata', monospace;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  cursor: default;
}

/* ── SCREENS ── */
.screen { display: none; min-height: 100vh; }
.screen.active { display: flex; }

/* ── TITLE SCREEN ── */
#screen-title {
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: radial-gradient(ellipse at 50% 30%, #1a1208 0%, #0a0805 70%);
  position: relative;
  text-align: center;
  padding: 2rem;
}

.title-fog {
  position: absolute; inset: 0;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
  pointer-events: none;
}

.title-main {
  font-family: 'Cinzel', serif;
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 700;
  letter-spacing: 0.15em;
  color: var(--amber);
  text-shadow: 0 0 40px rgba(200,146,42,0.3), 0 2px 0 #000;
  margin-bottom: 0.3rem;
}

.title-sub {
  font-family: 'Cinzel', serif;
  font-size: clamp(0.9rem, 2vw, 1.3rem);
  letter-spacing: 0.4em;
  color: var(--text-dim);
  margin-bottom: 0.8rem;
}

.title-divider {
  width: 200px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--amber-dim), transparent);
  margin: 1.5rem auto;
}

.title-quote {
  font-family: 'IM Fell English', serif;
  font-style: italic;
  font-size: 0.95rem;
  color: var(--text-dim);
  max-width: 500px;
  line-height: 1.6;
  margin-bottom: 3rem;
}

.btn-primary {
  font-family: 'Cinzel', serif;
  font-size: 0.9rem;
  letter-spacing: 0.2em;
  color: var(--bg);
  background: var(--amber);
  border: none;
  padding: 0.8rem 2.5rem;
  cursor: pointer;
  transition: all 0.2s;
  margin: 0.4rem;
}
.btn-primary:hover { background: var(--amber-bright); transform: translateY(-1px); }

.btn-ghost {
  font-family: 'Cinzel', serif;
  font-size: 0.85rem;
  letter-spacing: 0.15em;
  color: var(--text-dim);
  background: transparent;
  border: 1px solid var(--border2);
  padding: 0.7rem 2rem;
  cursor: pointer;
  transition: all 0.2s;
  margin: 0.4rem;
}
.btn-ghost:hover { color: var(--text); border-color: var(--amber-dim); }

/* ── MAIN GAME LAYOUT ── */
#screen-game {
  flex-direction: column;
  min-height: 100vh;
}

.game-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.6rem 1.2rem;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
  gap: 0.5rem;
}

.header-title {
  font-family: 'Cinzel', serif;
  font-size: 0.85rem;
  letter-spacing: 0.2em;
  color: var(--amber-dim);
}

.header-stats {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.stat-pill {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.75rem;
  color: var(--text-dim);
}

.stat-pill .label { letter-spacing: 0.1em; text-transform: uppercase; }
.stat-pill .val { color: var(--amber); font-weight: 700; min-width: 28px; }

.stat-bar-wrap { width: 60px; height: 5px; background: var(--bg3); border-radius: 2px; overflow: hidden; }
.stat-bar { height: 100%; border-radius: 2px; transition: width 0.4s; }
.bar-health { background: var(--red-bright); }
.bar-sanity { background: #6a9e8a; }
.bar-water  { background: #4a7a9e; }
.bar-food   { background: #8a7a3a; }

/* ── GAME BODY ── */
.game-body {
  display: grid;
  grid-template-columns: 220px 1fr 200px;
  flex: 1;
  min-height: 0;
}

@media (max-width: 900px) {
  .game-body { grid-template-columns: 1fr; }
  .sidebar-left, .sidebar-right { display: none; }
}

/* ── SIDEBARS ── */
.sidebar-left, .sidebar-right {
  background: var(--bg2);
  border-right: 1px solid var(--border);
  padding: 1rem;
  overflow-y: auto;
  font-size: 0.8rem;
}
.sidebar-right { border-right: none; border-left: 1px solid var(--border); }

.panel-title {
  font-family: 'Cinzel', serif;
  font-size: 0.7rem;
  letter-spacing: 0.25em;
  color: var(--amber-dim);
  border-bottom: 1px solid var(--border);
  padding-bottom: 0.5rem;
  margin-bottom: 0.8rem;
  text-transform: uppercase;
}

/* Inventory */
.inv-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 3px;
  margin-bottom: 1rem;
}
.inv-slot {
  aspect-ratio: 1;
  background: var(--bg3);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.65rem;
  cursor: pointer;
  transition: border-color 0.2s;
  position: relative;
  color: var(--text-dim);
  text-align: center;
  padding: 2px;
  line-height: 1.1;
}
.inv-slot:hover { border-color: var(--amber-dim); }
.inv-slot.filled { border-color: var(--border2); color: var(--amber); }
.inv-slot .qty {
  position: absolute; top: 1px; right: 2px;
  font-size: 0.55rem; color: var(--text-dim);
}

/* Shelter */
.shelter-display {
  background: var(--bg3);
  border: 1px solid var(--border);
  padding: 0.8rem;
  margin-bottom: 1rem;
  text-align: center;
}
.shelter-icon { font-size: 1.8rem; margin-bottom: 0.3rem; }
.shelter-name { color: var(--amber); font-size: 0.75rem; font-weight: 700; }
.shelter-level { color: var(--text-dim); font-size: 0.65rem; margin-top: 0.2rem; }

/* Status effects */
.status-list { display: flex; flex-direction: column; gap: 0.3rem; }
.status-tag {
  font-size: 0.65rem;
  padding: 0.25rem 0.5rem;
  border-left: 2px solid;
  background: var(--bg3);
  line-height: 1.3;
}
.status-tag.bad { border-color: var(--red-bright); color: #d07070; }
.status-tag.good { border-color: var(--green-bright); color: #70c090; }
.status-tag.neutral { border-color: var(--text-dim); color: var(--text-dim); }

/* Right sidebar — night info / lore */
.night-counter {
  text-align: center;
  padding: 1rem 0;
  border-bottom: 1px solid var(--border);
  margin-bottom: 1rem;
}
.night-num {
  font-family: 'Cinzel', serif;
  font-size: 2.5rem;
  color: var(--amber);
  line-height: 1;
}
.night-label { font-size: 0.65rem; letter-spacing: 0.2em; color: var(--text-dim); }
.night-of { font-size: 0.7rem; color: var(--text-dim); }

.lore-entry {
  background: var(--bg3);
  border: 1px solid var(--border);
  padding: 0.6rem;
  margin-bottom: 0.5rem;
  font-size: 0.68rem;
  line-height: 1.5;
  color: var(--text-dim);
  font-family: 'IM Fell English', serif;
  font-style: italic;
  cursor: pointer;
  transition: border-color 0.2s;
}
.lore-entry:hover { border-color: var(--amber-dim); color: var(--text); }
.lore-title { font-style: normal; font-family: 'Inconsolata', monospace; color: var(--amber); font-size: 0.65rem; letter-spacing: 0.1em; margin-bottom: 0.3rem; }

/* ── MAIN CONTENT AREA ── */
.game-center {
  display: flex;
  flex-direction: column;
  background: var(--bg);
  overflow: hidden;
}

.phase-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  padding: 0.5rem 1rem;
  border-bottom: 1px solid var(--border);
  background: var(--bg2);
}

.phase-tab {
  font-family: 'Cinzel', serif;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  color: var(--text-dim);
  padding: 0.3rem 1rem;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}
.phase-tab.active { color: var(--amber); border-bottom-color: var(--amber); }

/* Narrative area */
.narrative-area {
  flex: 1;
  overflow-y: auto;
  padding: 1.5rem;
  scroll-behavior: smooth;
}

.narr-block {
  max-width: 660px;
  margin: 0 auto 1.2rem;
  animation: fadeUp 0.4s ease;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

.narr-text {
  font-family: 'IM Fell English', serif;
  font-size: 1rem;
  line-height: 1.75;
  color: var(--text);
}

.narr-system {
  font-size: 0.75rem;
  color: var(--text-dim);
  letter-spacing: 0.05em;
  font-style: italic;
  padding: 0.3rem 0;
  border-left: 2px solid var(--border2);
  padding-left: 0.8rem;
}

.narr-event {
  background: var(--bg2);
  border: 1px solid var(--amber-dim);
  padding: 1rem 1.2rem;
  margin: 0.8rem 0;
}

.narr-event-title {
  font-family: 'Cinzel', serif;
  font-size: 0.8rem;
  letter-spacing: 0.15em;
  color: var(--amber);
  margin-bottom: 0.6rem;
  text-transform: uppercase;
}

.narr-event-text {
  font-family: 'IM Fell English', serif;
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--text);
  margin-bottom: 1rem;
}

.choices-wrap { display: flex; flex-direction: column; gap: 0.5rem; }

.choice-btn {
  background: var(--bg3);
  border: 1px solid var(--border2);
  color: var(--text);
  padding: 0.65rem 1rem;
  text-align: left;
  font-family: 'Inconsolata', monospace;
  font-size: 0.85rem;
  cursor: pointer;
  transition: all 0.2s;
  line-height: 1.4;
}
.choice-btn:hover:not(:disabled) { background: var(--surface); border-color: var(--amber); color: var(--amber-bright); }
.choice-btn:disabled { opacity: 0.4; cursor: default; }
.choice-letter {
  font-family: 'Cinzel', serif;
  color: var(--amber-dim);
  font-size: 0.75rem;
  margin-right: 0.7rem;
}

.outcome-good { border-left: 3px solid var(--green-bright); padding-left: 0.8rem; color: #80c8a0; }
.outcome-bad  { border-left: 3px solid var(--red-bright);   padding-left: 0.8rem; color: #c87070; }
.outcome-neutral { border-left: 3px solid var(--text-dim); padding-left: 0.8rem; }

/* Day actions */
.actions-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 0.5rem;
  padding: 1rem 0;
}

.action-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  padding: 0.8rem;
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
}
.action-card:hover { border-color: var(--amber-dim); background: var(--bg3); }
.action-icon { font-size: 1.5rem; margin-bottom: 0.4rem; }
.action-name { font-size: 0.75rem; color: var(--amber); font-family: 'Cinzel', serif; letter-spacing: 0.1em; margin-bottom: 0.2rem; }
.action-desc { font-size: 0.65rem; color: var(--text-dim); line-height: 1.3; }

/* Time button */
.time-btn-wrap {
  padding: 0.8rem 1.5rem;
  border-top: 1px solid var(--border);
  display: flex;
  justify-content: center;
  background: var(--bg2);
}

.time-btn {
  font-family: 'Cinzel', serif;
  font-size: 0.85rem;
  letter-spacing: 0.2em;
  padding: 0.7rem 2rem;
  cursor: pointer;
  border: 1px solid;
  transition: all 0.2s;
  background: transparent;
}
.time-btn.to-night { color: var(--amber-dim); border-color: var(--amber-dim); }
.time-btn.to-night:hover { color: var(--amber-bright); border-color: var(--amber-bright); background: rgba(200,146,42,0.08); }
.time-btn.to-day { color: #6a9e8a; border-color: #3a6e5a; }
.time-btn.to-day:hover { color: #90ceb0; border-color: #5a9e7a; }

/* Death / Win screens */
#screen-death, #screen-win {
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 2rem;
}

.death-title {
  font-family: 'Cinzel', serif;
  font-size: 3rem;
  color: var(--red-bright);
  letter-spacing: 0.2em;
  margin-bottom: 1rem;
}

.win-title {
  font-family: 'Cinzel', serif;
  font-size: 3rem;
  color: var(--amber);
  letter-spacing: 0.15em;
  margin-bottom: 1rem;
}

.death-msg, .win-msg {
  font-family: 'IM Fell English', serif;
  font-size: 1.1rem;
  color: var(--text-dim);
  max-width: 500px;
  line-height: 1.7;
  margin-bottom: 2rem;
}

/* Scrollbar */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border2); }

/* Intro dialog */
#intro-overlay {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(0,0,0,0.92);
  display: flex; align-items: center; justify-content: center;
  padding: 1rem;
}
.intro-box {
  background: var(--bg2);
  border: 1px solid var(--amber-dim);
  max-width: 580px;
  width: 100%;
  padding: 2rem;
}
.intro-box h2 {
  font-family: 'Cinzel', serif;
  color: var(--amber);
  letter-spacing: 0.15em;
  margin-bottom: 1.2rem;
  font-size: 1.1rem;
}
.intro-box p {
  font-family: 'IM Fell English', serif;
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--text);
  margin-bottom: 0.8rem;
}

/* Flicker animation for horror moments */
@keyframes flicker {
  0%,100% { opacity: 1; }
  92% { opacity: 1; }
  93% { opacity: 0.4; }
  94% { opacity: 1; }
  97% { opacity: 0.6; }
  98% { opacity: 1; }
}
.horror-moment { animation: flicker 4s infinite; }

.save-toast {
  position: fixed; bottom: 1rem; right: 1rem;
  background: var(--bg3); border: 1px solid var(--green-bright);
  color: var(--green-bright); padding: 0.4rem 0.9rem;
  font-size: 0.72rem; letter-spacing: 0.1em;
  opacity: 0; transition: opacity 0.3s; pointer-events: none;
  z-index: 200;
}
.save-toast.show { opacity: 1; }

.glitch-text {
  position: relative; display: inline-block;
}
</style>
</head>
<body>

<!-- ══════════ TITLE SCREEN ══════════ -->
<div id="screen-title" class="screen active">
  <div class="title-fog"></div>
  <div class="title-main">APALACHES</div>
  <div class="title-sub">30 noches</div>
  <div class="title-divider"></div>
  <p class="title-quote">"Los bosques tienen memoria. No todos los sonidos provienen de animales.
  No todas las voces pertenecen a los vivos."</p>
  <div>
    <button class="btn-primary" onclick="checkSave()">▸ COMENZAR</button><br>
    <button class="btn-ghost" onclick="showCredits()">Lore del mundo</button>
  </div>
</div>

<!-- ══════════ MAIN GAME SCREEN ══════════ -->
<div id="screen-game" class="screen">

  <!-- Header bar -->
  <div class="game-header">
    <div class="header-title">APALACHES</div>
    <div class="header-stats" id="header-stats"></div>
    <div style="font-size:0.7rem; color:var(--text-dim); cursor:pointer;" onclick="saveGame()">[ guardar ]</div>
  </div>

  <!-- 3-col layout -->
  <div class="game-body">

    <!-- LEFT SIDEBAR: inventory + shelter + statuses -->
    <div class="sidebar-left">
      <div class="panel-title">Refugio</div>
      <div class="shelter-display" id="shelter-display"></div>

      <div class="panel-title">Inventario</div>
      <div class="inv-grid" id="inv-grid"></div>

      <div class="panel-title">Estado</div>
      <div class="status-list" id="status-list"></div>
    </div>

    <!-- CENTER: narrative + actions -->
    <div class="game-center">
      <div class="phase-indicator">
        <div class="phase-tab active" id="tab-narrative">Narrativa</div>
        <div class="phase-tab" id="tab-map" onclick="showMap()">Mapa</div>
        <div class="phase-tab" id="tab-diario" onclick="showDiario()">Diario</div>
      </div>

      <div class="narrative-area" id="narrative-area"></div>

      <div class="time-btn-wrap" id="time-btn-area"></div>
    </div>

    <!-- RIGHT SIDEBAR: nights + lore -->
    <div class="sidebar-right">
      <div class="night-counter" id="night-counter"></div>

      <div class="panel-title">Pistas halladas</div>
      <div id="lore-panel"></div>
    </div>

  </div>
</div>

<!-- ══════════ DEATH SCREEN ══════════ -->
<div id="screen-death" class="screen">
  <div class="death-title">HAS MUERTO</div>
  <div class="death-msg" id="death-msg">La oscuridad te reclamó.</div>
  <button class="btn-primary" onclick="resetGame()">▸ VOLVER A INTENTARLO</button>
</div>

<!-- ══════════ WIN SCREEN ══════════ -->
<div id="screen-win" class="screen">
  <div class="win-title">HAS SOBREVIVIDO</div>
  <div class="win-msg" id="win-msg">Treinta noches en los Apalaches. Has visto lo que pocos han visto y regresado para contarlo. Aunque ya no eres exactamente el mismo.</div>
  <button class="btn-primary" onclick="resetGame()">▸ NUEVA PARTIDA</button>
</div>

<!-- Intro overlay -->
<div id="intro-overlay" style="display:none;">
  <div class="intro-box">
    <h2>INSTRUCCIONES</h2>
    <p>Estás solo en los Apalaches. Tu objetivo: sobrevivir 30 noches.</p>
    <p><strong style="color:var(--amber)">Durante el día</strong> — Explora, recolecta, construye y cuida tu mente. Elige acciones sabiamente: tienes energía limitada.</p>
    <p><strong style="color:var(--amber)">Durante la noche</strong> — Algo ocurre. Siempre ocurre algo. Tus decisiones pueden significar la diferencia entre vivir y no hacerlo.</p>
    <p>La cordura es tan importante como el agua. El bosque recuerda.</p>
    <button class="btn-primary" style="margin-top:1rem;" onclick="closeIntro()">▸ ENTRAR AL BOSQUE</button>
  </div>
</div>

<!-- Save toast -->
<div class="save-toast" id="save-toast">✓ partida guardada</div>

<script>
// ═══════════════════════════════════════════════════════
//  GAME STATE
// ═══════════════════════════════════════════════════════
let G = {
  night: 1,
  phase: 'day', // 'day' | 'night'
  dayActionsLeft: 4,
  player: { health: 100, sanity: 80, water: 80, food: 80, stamina: 100 },
  shelter: 0, // 0=intemperie,1=suelo,2=seto,3=tienda,4=cabaña,5=refugio
  inventory: [],
  statuses: [],
  lore: [],
  flags: {},
  log: [],
  deathMsg: ''
};

const SHELTER_NAMES = ['Intemperie','Suelo improvisado','Seto improvisado','Tienda de campaña','Cabaña improvisada','Refugio avanzado'];
const SHELTER_ICONS = ['🌲','🍂','🌿','⛺','🪵','🏚️'];
const SHELTER_DEFENSE = [0,5,15,35,60,85];

// ── Items ──
const ITEMS = {
  agua:        { name:'Agua',       icon:'💧', max:3, effect:'Restaura hidratación.',  type:'consumable' },
  comida:      { name:'Comida',     icon:'🥫', max:3, effect:'Restaura energía.',      type:'consumable' },
  vendaje:     { name:'Vendaje',    icon:'🩹', max:2, effect:'Cura heridas menores.',  type:'consumable' },
  linterna:    { name:'Linterna',   icon:'🔦', max:1, effect:'Ilumina la noche. Atrae cosas.', type:'tool' },
  pilas:       { name:'Pilas',      icon:'🔋', max:2, effect:'Carga la linterna.',     type:'consumable' },
  cuerda:      { name:'Cuerda',     icon:'🪢', max:1, effect:'Útil en construcción.',  type:'material' },
  madera:      { name:'Madera',     icon:'🪵', max:3, effect:'Construir y calentar.',  type:'material' },
  navaja:      { name:'Navaja',     icon:'🔪', max:1, effect:'Herramienta polivalente.', type:'tool' },
  brujula:     { name:'Brújula',    icon:'🧭', max:1, effect:'No te pierdas.',         type:'tool' },
  antidoto:    { name:'Antídoto',   icon:'💊', max:2, effect:'Cura veneno o infección.', type:'consumable' },
  nota_vieja:  { name:'Nota hallada', icon:'📄', max:1, effect:'Una nota de alguien que estuvo aquí.', type:'lore' },
  diario:      { name:'Diario roto', icon:'📓', max:1, effect:'Páginas arrancadas, escritura febril.', type:'lore' },
