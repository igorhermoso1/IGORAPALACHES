// ── Wildlife encounters during day exploration ──
const WILDLIFE_EVENTS = [
  {
    chance: 0.15,
    fn: () => {
      if (Math.random() < 0.5) {
        G.player.health = Math.max(0, G.player.health - 8);
        addStatus({ id:'picadura', name:'Picadura de insecto — fiebre leve posible', type:'bad' });
        addNarr('<div class="narr-text" style="color:#c87070;">Algo te pica en el cuello mientras exploras. Una araña o un insecto. El dolor es agudo pero pasa pronto.</div>');
        addSystem('-8 salud, estado: picadura');
      }
    }
  },
  {
    chance: 0.1,
    fn: () => {
      G.player.health = Math.max(0, G.player.health - 12);
      G.player.sanity = Math.max(0, G.player.sanity - 8);
      addStatus({ id:'susto_oso', name:'Encuentro con oso — adrenalina alta', type:'neutral' });
      addNarr('<div class="narr-text" style="color:#c87070;">Un oso negro cruza el sendero a diez metros. Os miráis. Se aleja. Tardas veinte minutos en dejar de temblar.</div>');
      addSystem('-12 salud, -8 cordura');
    }
  },
  {
    chance: 0.08,
    fn: () => {
      addLore('Lobo solitario observando desde la cresta. No se acercó, pero tampoco se fue durante media hora.');
      addNarr('<div class="narr-text">Un lobo solitario en la cresta te observa durante media hora exacta. Luego desaparece. No habías visto lobos en estos montes según los registros recientes.</div>');
    }
  },
  {
    chance: 0.12,
    fn: () => {
      G.player.food = Math.min(100, G.player.food + 15);
      addNarr('<div class="narr-text">Un ciervo real cruza el claro. Se mueve como un ciervo. Sus ojos reflejan la luz correctamente. La normalidad, cuando aparece, resulta reconfortante.</div>');
      addSystem('+15 comida (calma)');
    }
  },
  {
    chance: 0.06,
    fn: () => {
      G.player.health = Math.max(0, G.player.health - 18);
      G.deathMsg = 'La serpiente era de cascabel. Sin antídoto, el veneno hizo su trabajo.';
      addStatus({ id:'veneno', name:'Envenenado — requiere antídoto urgente', type:'bad' });
      addNarr('<div class="narr-text" style="color:#c43030;">Una serpiente de cascabel bajo una roca. La pisas. El dolor es inmediato.</div>');
      addSystem('-18 salud, estado: VENENO — usa antídoto pronto');
      checkVitals();
    }
  },
];

const LORE_EVENTS = [
  'Huellas en el barro: empiezan siendo de ciervo y terminan, tres metros después, siendo bípedas.',
  'Nombre grabado con profundidad en un tronco: ELEANOR. Debajo, más pequeño: "no la sigas".',
  'Círculo de piedras con ceniza interior reciente. Nadie debería haber estado aquí esta semana.',
  'Una fotografía clavada en un árbol boca abajo. Al girarla, la imagen ha cambiado respecto a cuando fue tomada.',
  'Un silbido lejano repetitivo. Tu boca empieza a imitarlo involuntariamente antes de que te des cuenta.',
  'Las Brown Mountain Lights: tres puntos luminosos en patrón triangular sobre la cresta norte.',
  '"Wood Booger" grabado en un árbol caído junto a huellas de unos 45 cm de longitud.',
  'Un par de botas abandonadas en el centro de un sendero. Sin dueño a la vista. Orientadas hacia el bosque.',
  'Árboles con la corteza raspada a tres metros de altura. No hay nada en la fauna local que alcance esa altura.',
  'Una nota clavada en un árbol: "SI LEES ESTO NO DUERMAS EN EL CLARO NORTE". Sin firma. Con fecha reciente.',
  'Huesos de animales dispuestos en patrón geométrico. No por predador natural. Por manos.',
  'Una cabaña en ruinas con una sola silla en el centro. El suelo alrededor de la silla está desgastado en círculo.',
];

// ═══════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════
function init() {
  renderAll();
}

function checkSave() {
  const saved = localStorage.getItem('apalaches_save');
  if (saved) {
    if (confirm('Hay una partida guardada. ¿Continuar?')) {
      G = JSON.parse(saved);
      showScreen('game');
      renderAll();
      addNarr('<span class="narr-system">// Partida cargada. Noche ' + G.night + '. El bosque te recuerda.</span>');
    } else {
      startNewGame();
    }
  } else {
    startNewGame();
  }
}

function startNewGame() {
  G = {
    night:1, phase:'day', dayActionsLeft:4,
    player:{ health:100, sanity:80, water:80, food:80, stamina:100 },
    shelter:0, inventory:[], statuses:[], lore:[], flags:{}, log:[],
    deathMsg:''
  };
  showScreen('game');
  renderAll();
  document.getElementById('intro-overlay').style.display = 'flex';
}

function closeIntro() {
  document.getElementById('intro-overlay').style.display = 'none';
  addNarr(`<div class="narr-text">El coche se aleja. Solo el silencio de los Apalaches queda contigo.
    <br><br>Tu refugio improvisado es poco más que nada. Tienes que sobrevivir <strong style="color:var(--amber)">30 noches</strong>.
    El primer día comienza. Tienes <strong style="color:var(--amber)">${G.dayActionsLeft} acciones</strong> antes del anochecer.</div>`);
  renderDayActions();
}

// ═══════════════════════════════════════════════════════
//  RENDER
// ═══════════════════════════════════════════════════════
function renderAll() {
  renderHeaderStats();
  renderShelter();
  renderInventory();
  renderStatuses();
  renderNightCounter();
  renderLorePanel();
  renderTimeBtns();
}

function renderHeaderStats() {
  const p = G.player;
  document.getElementById('header-stats').innerHTML = `
    <div class="stat-pill"><span class="label">salud</span><div class="stat-bar-wrap"><div class="stat-bar bar-health" style="width:${p.health}%"></div></div><span class="val">${Math.round(p.health)}</span></div>
    <div class="stat-pill"><span class="label">cordura</span><div class="stat-bar-wrap"><div class="stat-bar bar-sanity" style="width:${p.sanity}%"></div></div><span class="val">${Math.round(p.sanity)}</span></div>
    <div class="stat-pill"><span class="label">agua</span><div class="stat-bar-wrap"><div class="stat-bar bar-water" style="width:${p.water}%"></div></div><span class="val">${Math.round(p.water)}</span></div>
    <div class="stat-pill"><span class="label">comida</span><div class="stat-bar-wrap"><div class="stat-bar bar-food" style="width:${p.food}%"></div></div><span class="val">${Math.round(p.food)}</span></div>
  `;
}

function renderShelter() {
  document.getElementById('shelter-display').innerHTML = `
    <div class="shelter-icon">${SHELTER_ICONS[G.shelter]}</div>
    <div class="shelter-name">${SHELTER_NAMES[G.shelter]}</div>
    <div class="shelter-level">Defensa: ${SHELTER_DEFENSE[G.shelter]}%</div>
  `;
}

function renderInventory() {
  const grid = document.getElementById('inv-grid');
  const SLOTS = 20;
  // Flatten inventory for display
  const items = [];
  G.inventory.forEach(e => {
    items.push({ key: e.key, qty: e.qty, data: ITEMS[e.key] });
  });
  let html = '';
  for (let i = 0; i < SLOTS; i++) {
    if (items[i]) {
      const it = items[i];
      html += `<div class="inv-slot filled" onclick="useItem('${it.key}')" title="${it.data.effect}">
        <span>${it.data.icon}</span>
        <span class="qty">${it.qty > 1 ? it.qty : ''}</span>
      </div>`;
    } else {
      html += `<div class="inv-slot"></div>`;
    }
  }
  grid.innerHTML = html;
}

function renderStatuses() {
  const list = document.getElementById('status-list');
  if (!G.statuses.length) {
    list.innerHTML = '<div style="font-size:0.65rem;color:var(--text-dim);font-style:italic;">Sin efectos activos.</div>';
    return;
  }
  list.innerHTML = G.statuses.map(s =>
    `<div class="status-tag ${s.type}">${s.name}</div>`
  ).join('');
}

function renderNightCounter() {
  document.getElementById('night-counter').innerHTML = `
    <div class="night-label">NOCHE</div>
    <div class="night-num">${G.night}</div>
    <div class="night-of">de 30</div>
  `;
}

function renderLorePanel() {
  const panel = document.getElementById('lore-panel');
  if (!G.lore.length) {
    panel.innerHTML = '<div style="font-size:0.65rem;color:var(--text-dim);font-style:italic;">Nada descubierto aún.</div>';
    return;
  }
  panel.innerHTML = G.lore.slice(-5).reverse().map(l => `
    <div class="lore-entry">${l}</div>
  `).join('');
}

function renderTimeBtns() {
  const area = document.getElementById('time-btn-area');
  if (G.phase === 'day') {
    area.innerHTML = `<button class="time-btn to-night" onclick="beginNight()">⬛ ESPERAR EL ANOCHECER</button>`;
  } else {
    area.innerHTML = '';
  }
}

// ═══════════════════════════════════════════════════════
//  NARRATIVE
// ═══════════════════════════════════════════════════════
function addNarr(html) {
  const area = document.getElementById('narrative-area');
  const block = document.createElement('div');
  block.className = 'narr-block';
  block.innerHTML = html;
  area.appendChild(block);
  setTimeout(() => block.scrollIntoView({ behavior:'smooth', block:'nearest' }), 50);
}

function addSystem(txt) {
  addNarr(`<div class="narr-system">// ${txt}</div>`);
}

// ═══════════════════════════════════════════════════════
//  DAY PHASE
// ═══════════════════════════════════════════════════════
function renderDayActions() {
  if (G.phase !== 'day') return;
  if (G.dayActionsLeft <= 0) {
    addNarr(`<div class="narr-system">// No quedan más acciones para hoy. Puedes esperar el anochecer.</div>`);
    return;
  }
  const avail = DAY_ACTIONS.filter(a => {
    if (a.id === 'build' && G.shelter >= 5) return false;
    return true;
  });
  let html = `<div class="narr-event">
    <div class="narr-event-title">⬛ ACCIONES DEL DÍA — ${G.dayActionsLeft} restantes</div>
    <div class="actions-grid">
    ${avail.map(a => `
      <div class="action-card" onclick="doAction('${a.id}')">
        <div class="action-icon">${a.icon}</div>
        <div class="action-name">${a.name}</div>
        <div class="action-desc">${a.desc}</div>
      </div>
    `).join('')}
    </div>
  </div>`;
  addNarr(html);
}

function doAction(id) {
  if (G.phase !== 'day' || G.dayActionsLeft <= 0) return;
  const action = DAY_ACTIONS.find(a => a.id === id);
  if (!action) return;
  G.dayActionsLeft--;

  // Apply stamina cost
  if (action.cost.stamina) G.player.stamina = Math.max(0, G.player.stamina - action.cost.stamina);

  // Passive decay each action
  G.player.water = Math.max(0, G.player.water - 8);
  G.player.food  = Math.max(0, G.player.food - 6);

  // Call the action function
  action.fn();

  // Check vitals
  checkVitals();
  renderAll();

  // Show next actions if any left
  setTimeout(() => renderDayActions(), 300);
}

function doExplore() {
  const find = EXPLORE_FINDS[Math.floor(Math.random() * EXPLORE_FINDS.length)];
  addItem(find.item, find.qty || 1);
  if (find.lore) addLore(find.lore);
  // Chance of ambient lore find
  if (Math.random() < 0.35) addLore(LORE_EVENTS[Math.floor(Math.random() * LORE_EVENTS.length)]);
  addNarr(`<div class="narr-text">Exploras el perímetro del bosque durante horas. <em>${find.msg}</em></div>`);
  addSystem(`+${find.qty||1} ${ITEMS[find.item].name}`);

  // Wildlife encounter chance
  for (const w of WILDLIFE_EVENTS) {
    if (Math.random() < w.chance) {
      w.fn();
      break;
    }
  }
}

function doBuild() {
  const has_material = hasItem('madera') || hasItem('tela') || hasItem('cuerda');
  if (!has_material) {
    addNarr('<div class="narr-system">// Necesitas materiales para construir (madera, tela, cuerda).</div>');
    return;
  }
  if (G.shelter < 5) {
    // Consume a material
    if (hasItem('madera')) removeItem('madera', 1);
    else if (hasItem('tela')) removeItem('tela', 1);
    else removeItem('cuerda', 1);

    const before = SHELTER_NAMES[G.shelter];
    G.shelter++;
    const after = SHELTER_NAMES[G.shelter];
    addNarr(`<div class="narr-text">Trabajas con lo que tienes. El refugio mejora.</div>`);
    addSystem(`Refugio: ${before} → ${after}`);
  }
}

function doRest() {
  const staminaGain = 30 + Math.floor(Math.random() * 20);
  G.player.stamina = Math.min(100, G.player.stamina + staminaGain);
  // Shelter quality affects sanity restoration
  const sanityGain = 8 + G.shelter * 4;
  G.player.sanity = Math.min(100, G.player.sanity + sanityGain);
  // Fever recovery chance
  if (G.statuses.find(s => s.id === 'picadura') && Math.random() < 0.5) {
    removeStatus('picadura');
    addSystem('La picadura sanó con el descanso');
  }
  const msgs = [
    'El silencio del día es casi reconfortante. Casi. Los pájaros suenan normales de día.',
    'Cierras los ojos un momento. El bosque no desaparece de tu mente, pero el cuerpo descansa.',
    'Descanso breve. Por ahora todo parece dentro de parámetros normales.',
    'Te sientas contra el árbol más cercano. Recuerdas por qué viniste. Todavía no lo entiendes.',
    `La calidad del ${SHELTER_NAMES[G.shelter].toLowerCase()} marca la diferencia en el descanso.`,
  ];
  addNarr(`<div class="narr-text">${msgs[Math.floor(Math.random()*msgs.length)]}</div>`);
  addSystem(`+${staminaGain} energía, +${sanityGain} cordura`);
}

function doWater() {
  const found = Math.random() < 0.8;
  if (found) {
    addItem('agua', 1 + (Math.random() < 0.4 ? 1 : 0));
    G.player.water = Math.min(100, G.player.water + 30);
    const msgs = [
      'El arroyo de la ladera norte sigue activo. Agua fría y relativamente limpia.',
      'Una charca de lluvia entre rocas. Filtras lo que puedes con la tela.',
      'El manantial al oeste del claro. Alguien lo marcó con piedras apiladas.',
    ];
    addNarr(`<div class="narr-text">${msgs[Math.floor(Math.random()*msgs.length)]}</div>`);
    addSystem('+Agua, +30 hidratación');
  } else {
    addNarr('<div class="narr-text">El arroyo está seco por la sequía. Tendrás que buscar más lejos mañana.</div>');
    G.player.water = Math.max(0, G.player.water - 5);
  }
}

function doForage() {
  const roll = Math.random();
  if (roll < 0.55) {
    const qty = Math.random() < 0.3 ? 2 : 1;
    addItem('bayas', qty);
    G.player.food = Math.min(100, G.player.food + 20 * qty);
    addNarr('<div class="narr-text">Bayas silvestres reconocibles. Las pruebas antes de cogerlas todas. Sabor correcto.</div>');
    addSystem(`+${qty} Bayas, +${20*qty} comida`);
  } else if (roll < 0.65) {
    // Found bad berries
    G.player.health = Math.max(0, G.player.health - 12);
    G.player.food = Math.min(100, G.player.food + 10);
    addStatus({ id:'intoxicacion', name:'Intoxicación leve — náuseas', type:'bad' });
    addNarr('<div class="narr-text" style="color:#c87070;">Algunas bayas tenían mal aspecto y las comiste igual. Náuseas durante horas.</div>');
    addSystem('-12 salud, estado: intoxicación');
  } else {
    addNarr('<div class="narr-text">El bosque no da hoy. La estación, la humedad, o algo más lo explica. Vuelves con las manos vacías.</div>');
  }
}

function doInvestigate() {
  // Costs more sanity the later the game
  const sanityPenalty = Math.min(15, 5 + Math.floor(G.night / 5));
  G.player.sanity = Math.max(0, G.player.sanity - sanityPenalty);

  const entries = [
    'Huellas de ciervo que se transforman gradualmente en huellas bípedas y luego desaparecen en una roca.',
    'Un nombre grabado en un árbol caído: MARGARET. Abajo, en letras más pequeñas: "no respondas si te llama".',
    'Círculo de piedras. El suelo interior está quemado pero la hierba alrededor está intacta y sana.',
    'Una fotografía clavada en un árbol con algo afilado. La cara está borrada con el mismo objeto.',
    'Restos de campamento. El fuego lleva semanas frío. Nadie recogió los objetos personales.',
    'Árboles doblados hacia el mismo punto cardinal. No fue el viento. El ángulo es demasiado consistente.',
    'Una calavera de ciervo perfectamente limpia, apoyada contra un árbol, orientada hacia el sur.',
    'Símbolos repetidos en varios troncos. El mismo patrón. Demasiado idéntico para ser coincidencia.',
  ];
  const e = entries[G.night % entries.length] || entries[Math.floor(Math.random()*entries.length)];
  addLore(e);
  addNarr(`<div class="narr-text">Sigues marcas extrañas durante horas. Lo que encuentras no tiene explicación simple.<br><br><em style="color:var(--text-dim)">${e}</em></div>`);
  addSystem(`-${sanityPenalty} cordura (investigar tiene un coste mental)`);
}

function doMeditate() {
  const gain = 18 + Math.floor(Math.random() * 15) + G.shelter * 2;
  G.player.sanity = Math.min(100, G.player.sanity + gain);
  // Remove intoxication via rest
  if (G.statuses.find(s => s.id === 'intoxicacion') && Math.random() < 0.6) {
    removeStatus('intoxicacion');
    addSystem('La náusea pasó con el descanso mental');
  }
  const msgs = [
    'Técnicas de control. Respirar. Contar hacia atrás. Nombrar cosas reales. Por ahora funciona.',
    'Media hora de silencio activo. Recuerdas quién eres. El bosque no puede quitarte eso.',
    'El ejercicio de anclaje: cinco cosas que ves, cuatro que tocas, tres que oyes. Funciona.',
  ];
  addNarr(`<div class="narr-text">${msgs[Math.floor(Math.random()*msgs.length)]}</div>`);
  addSystem(`+${gain} cordura`);
}

function doCraft() {
  // Expanded crafting options
  if (hasItem('madera') && hasItem('tela') && !G.flags.craftedTrap) {
    removeItem('madera', 1); removeItem('tela', 1);
    G.flags.craftedTrap = true;
    addStatus({ id:'trampa_activa', name:'Trampa de perimetro activa — alerta de intrusos', type:'good' });
    addNarr('<div class="narr-text">Construyes un sistema primitivo de alarma perimetral con cuerda y latas. No es gran cosa, pero te dará tiempo de reacción.</div>');
    addSystem('Trampa de perímetro construida (+alerta nocturna)');
  } else if (hasItem('madera') && !hasItem('navaja')) {
    removeItem('madera', 1);
    addItem('navaja', 1);
    addNarr('<div class="narr-text">Afinas madera dura hasta conseguir algo con filo usable. Rústico, pero mejor que nada.</div>');
    addSystem('+1 Navaja tallada');
  } else if (hasItem('tela') && !G.flags.craftedBandage) {
    removeItem('tela', 1);
    addItem('vendaje', 2);
    G.flags.craftedBandage = true;
    addNarr('<div class="narr-text">Con la tela improvisas dos vendajes decentes. Material médico básico pero útil.</div>');
    addSystem('+2 Vendaje improvisado');
  } else if (hasItem('cuerda') && hasItem('madera') && !G.flags.craftedFire) {
    removeItem('cuerda', 1); removeItem('madera', 1);
    G.flags.craftedFire = true;
    addItem('madera', 2);
    addNarr('<div class="narr-text">Construyes un kit de fuego por fricción. Con práctica y esta madera seca, podrás tener fuego en minutos.</div>');
    addSystem('Kit de fuego listo — el fuego ya no requiere madera directa en eventos');
  } else {
    addNarr('<div class="narr-system">// Con los materiales actuales no hay más artesanía posible. Explora para encontrar madera, tela o cuerda.</div>');
  }
}

// ═══════════════════════════════════════════════════════
//  NIGHT PHASE
// ═══════════════════════════════════════════════════════
function beginNight() {
  G.phase = 'night';
  G.player.water = Math.max(0, G.player.water - 12);
  G.player.food  = Math.max(0, G.player.food - 10);

  // Atmospheric night opener varies by progression
  const openers = [
    'El sol desaparece detrás de las cimas. Los Apalaches cambian cuando oscurece. Lo que era familiar se vuelve ajeno.',
    'La oscuridad de los Apalaches no es como la de la ciudad. Es completa, antigua, viva.',
    'Los grillos enmudecen antes de lo normal. El bosque está en silencio. Eso nunca es buena señal.',
    'La luna esta noche ilumina lo suficiente para ver siluetas. También para que las siluetas te vean a ti.',
    'Noche ' + G.night + '. Las primeras noches parecían largas. Ahora cada una parece más corta, más densa.',
    'Algo en el aire ha cambiado. El olor del bosque nocturno lleva algo nuevo esta noche.',
    'La temperatura baja más rápido de lo habitual. El frío tiene textura propia aquí dentro.',
  ];
  addNarr(`<div class="narr-text" style="color:var(--text-dim);font-style:italic;">${openers[G.night % openers.length]}</div>`);

  // Milestone narrative messages
  if (G.night === 5) addNarr(`<div class="narr-system">// Quinta noche. El patrón empieza a volverse reconocible. Lo que ocurre aquí no es aleatorio.</div>`);
  if (G.night === 10) addNarr(`<div class="narr-event"><div class="narr-event-title">⬛ DÉCIMA NOCHE</div><div class="narr-event-text">Diez noches en los Apalaches. Hay algo que cambia en alguien después de tanto tiempo aquí. Lo que antes parecía imposible ya solo parece inusual.</div></div>`);
  if (G.night === 15) addNarr(`<div class="narr-event"><div class="narr-event-title">⬛ QUINCE NOCHES</div><div class="narr-event-text">A mitad del camino. Has aprendido reglas que nadie te enseñó: no respondas a tu nombre, no sigas las luces, no mires demasiado tiempo lo que no quiere ser mirado.</div></div>`);
  if (G.night === 20) addNarr(`<div class="narr-event"><div class="narr-event-title">⬛ VEINTE NOCHES</div><div class="narr-event-text">Veinte noches. Los registros de la grabadora llegan hasta aquí. Nadie que la dejó sobrevivió más allá de esta noche. Tú estás a punto de ser la excepción.</div></div>`);
  if (G.night === 25) addNarr(`<div class="narr-event"><div class="narr-event-title">⬛ VEINTICINCO NOCHES</div><div class="narr-event-text">Cinco noches más. El bosque lo sabe. Noche veinticinco — algo ha cambiado en la frecuencia de los eventos. Como si el entorno estuviera probando un límite antes de que lo alcances.</div></div>`);

  renderAll();
  setTimeout(launchNightEvents, 1200);
}

function launchNightEvents() {
  // Scale event count with progression
  const count = (G.night > 8 && Math.random() < 0.5) ? 2 : (G.night > 20 && Math.random() < 0.3) ? 3 : 1;
  const eventsAvail = [...getEventPool()];
  shuffle(eventsAvail);

  // Filter by flags to avoid immediate repeat
  const used = G.flags.lastEvents || [];
  const filtered = eventsAvail.filter(e => !used.includes(e.id));
  const pool = filtered.length >= count ? filtered : eventsAvail;

  const chosen = pool.slice(0, count);
  G.flags.lastEvents = chosen.map(e => e.id);

  // Show events in sequence
  let delay = 800;
  chosen.forEach((evt, idx) => {
    setTimeout(() => showNightEvent(evt, idx === chosen.length - 1), delay);
    delay += 500;
  });
}

function showNightEvent(evt, isLast) {
  const letters = ['A','B','C','D'];
  const isLastStr = isLast ? 'true' : 'false';
  const choicesHtml = evt.choices.map((c, i) => {
    const locked = c.requires && !hasItem(c.requires);
    const reqName = c.requires ? (ITEMS[c.requires]?.name || c.requires) : '';
    const reqIcon = c.requires ? (ITEMS[c.requires]?.icon || '') : '';
    return `<button class="choice-btn" ${locked?'disabled':''} onclick="resolveChoice(this,'${evt.id}',${i},'${isLastStr}')">
      <span class="choice-letter">${letters[i]}.</span>${c.text}
      ${locked ? `<span style="color:var(--text-dim);font-size:0.72rem;"> [necesitas: ${reqIcon} ${reqName}]</span>` : ''}
    </button>`;
  }).join('');

  addNarr(`<div class="narr-event">
    <div class="narr-event-title">🌑 ${evt.title}</div>
    <div class="narr-event-text">${evt.text}</div>
    <div class="choices-wrap" id="choices_${evt.id}">${choicesHtml}</div>
  </div>`);
}

function resolveChoice(btn, evtId, choiceIdx, isLastStr) {
  // Disable all choices in this event
  const wrap = document.getElementById('choices_' + evtId);
  if (wrap) wrap.querySelectorAll('.choice-btn').forEach(b => b.disabled = true);

  const evt = NIGHT_EVENTS.find(e => e.id === evtId);
  if (!evt) return;
  const choice = evt.choices[choiceIdx];
  if (!choice) return;

  // Apply deltas
  const delta = choice.delta || {};
  Object.keys(delta).forEach(k => {
    if (k in G.player) {
      G.player[k] = Math.max(0, Math.min(100, G.player[k] + delta[k]));
    }
  });

  // Consume item if it's a consumable
  if (choice.requires && hasItem(choice.requires)) {
    if (ITEMS[choice.requires]?.type === 'consumable') {
      removeItem(choice.requires, 1);
    }
  }

  // Add lore if the choice unlocks it
  if (choice.lore) addLore(choice.lore);

  const cls = choice.outcome === 'good' ? 'outcome-good' : choice.outcome === 'bad' ? 'outcome-bad' : 'outcome-neutral';
  addNarr(`<div class="narr-block"><div class="${cls} narr-text">${choice.msg}</div></div>`);

  // Stat changes summary
  const parts = [];
  if (delta.health) parts.push(`${delta.health > 0 ? '+' : ''}${delta.health} salud`);
  if (delta.sanity) parts.push(`${delta.sanity > 0 ? '+' : ''}${delta.sanity} cordura`);
  if (parts.length) addSystem(parts.join(', '));

  // Apply shelter defense bonus on bad outcomes
  if (choice.outcome === 'bad' && G.shelter > 0) {
    const saved = Math.floor(SHELTER_DEFENSE[G.shelter] * 0.2);
    if (saved > 0) {
      G.player.health = Math.min(100, G.player.health + saved);
      addSystem(`+${saved} salud (defensa del refugio)`);
    }
  }

  checkVitals();
  renderAll();

  // End night if this was the last event
  if (isLastStr === 'true') {
    setTimeout(endNight, 2000);
  }
}

function endNight() {
  const dawns = [
    'El amanecer comienza a abrirse paso entre los árboles. Has sobrevivido otra noche.',
    'La luz llega despacio, como si el bosque la dejara pasar de mala gana.',
    'Los pájaros empiezan antes del alba. El sonido más hermoso que hayas escuchado.',
    'Gris. Luego azul. Luego luz. El amanecer en los Apalaches tiene su propio protocolo.',
    'La niebla de la mañana borra las huellas de lo que rondó esta noche. Agradeces no saber.',
  ];
  addNarr(`<div class="narr-text" style="color:var(--text-dim);font-family:'IM Fell English',serif;font-style:italic;">
    ${dawns[G.night % dawns.length]}
  </div>`);

  G.night++;
  G.phase = 'day';
  G.dayActionsLeft = 4 + (G.shelter >= 3 ? 1 : 0); // better shelter = more daylight actions
  G.player.stamina = Math.min(100, G.player.stamina + 30);
  G.player.sanity  = Math.min(100, G.player.sanity  + 3); // small sanity reward for surviving

  if (G.night > 30) {
    setTimeout(showWin, 1500);
    return;
  }

  addSystem(`Día ${G.night} — ${G.dayActionsLeft} acciones disponibles`);
  if (G.shelter >= 3) addSystem('(+1 acción por refugio mejorado)');
  renderAll();
  saveGame(true);
  setTimeout(renderDayActions, 900);
}

function showWin() {
  const loreCount = G.lore.length;
  const nightsSurvived = 30;
  const finalSanity = Math.round(G.player.sanity);

  let endingText = '';
  if (finalSanity > 70) {
    endingText = 'Saliste con la mente intacta. Pocas personas pueden decir lo mismo después de treinta noches en los Apalaches. Quizás lo que viste fue solo la naturaleza. Quizás no.';
  } else if (finalSanity > 40) {
    endingText = 'Saliste. Eso es lo que importa. La mente tardará semanas en reajustarse. Algunos recuerdos nunca encajarán con ninguna categoría. Aprenderás a convivir con eso.';
  } else {
    endingText = 'Saliste, pero algo se quedó dentro del bosque. O algo del bosque se quedó dentro de ti. En cualquier caso, ya no eres exactamente quien entró.';
  }

  document.getElementById('win-msg').innerHTML = `${endingText}
    <br><br>
    <div style="font-family:'Inconsolata',monospace;font-size:0.8rem;color:var(--amber-dim);line-height:2;">
      ESTADÍSTICAS FINALES<br>
      Noches sobrevividas: ${nightsSurvived}/30<br>
      Cordura final: ${finalSanity}%<br>
      Pistas descubiertas: ${loreCount}<br>
      Refugio alcanzado: ${SHELTER_NAMES[G.shelter]}
    </div>`;
  localStorage.removeItem('apalaches_save');
  showScreen('win');
}

// ── Status helpers ──
function addStatus(s) {
  if (!G.statuses.find(x => x.id === s.id)) {
    G.statuses.push(s);
    renderStatuses();
  }
}

function removeStatus(id) {
  G.statuses = G.statuses.filter(s => s.id !== id);
  renderStatuses();
}

// ═══════════════════════════════════════════════════════
//  VITALS CHECK
// ═══════════════════════════════════════════════════════
function checkVitals() {
  const p = G.player;

  // Remove old auto-statuses
  const autoIds = ['auto_thirst','auto_hunger','auto_weak_sanity','auto_fever'];
  G.statuses = G.statuses.filter(s => !autoIds.includes(s.id));

  // Re-evaluate persistent conditions
  if (p.water < 25) addStatus({ id:'auto_thirst', name:'Sed extrema — salud decrece', type:'bad' });
  if (p.food  < 25) addStatus({ id:'auto_hunger', name:'Hambre severa — salud decrece', type:'bad' });
  if (p.sanity < 30) addStatus({ id:'auto_weak_sanity', name:'Al borde de la locura', type:'bad' });

  // Poison tick
  if (G.statuses.find(s => s.id === 'veneno')) {
    p.health = Math.max(0, p.health - 6);
    addSystem('El veneno avanza: -6 salud. Usa antídoto.');
  }

  // Fever tick from bite
  if (G.statuses.find(s => s.id === 'picadura') && Math.random() < 0.3) {
    p.health = Math.max(0, p.health - 4);
    p.sanity = Math.max(0, p.sanity - 3);
    addStatus({ id:'auto_fever', name:'Fiebre de picadura — recupera con descanso', type:'bad' });
  }

  // Hunger/thirst progressive damage
  if (p.water < 15) p.health = Math.max(0, p.health - 6);
  if (p.food  < 15) p.health = Math.max(0, p.health - 4);

  // Sanity floor from long exposure
  if (G.night > 15 && p.sanity < 50) {
    p.sanity = Math.max(0, p.sanity - 1);
  }

  // Death check
  if (p.health <= 0) {
    if (!G.deathMsg) G.deathMsg = 'Tu cuerpo finalmente cedió. Los Apalaches te reclamaron.';
    showDeath(); return;
  }
  if (p.sanity <= 0) {
    G.deathMsg = 'La locura tomó el control. En algún momento dejaste de saber quién eras. Los que te buscaron encontraron el refugio vacío.';
    showDeath(); return;
  }
  if (p.water <= 0) {
    G.deathMsg = 'La deshidratación te venció. El agua era tan importante como todo lo demás.';
    showDeath(); return;
  }
}

// ═══════════════════════════════════════════════════════
//  INVENTORY HELPERS
// ═══════════════════════════════════════════════════════
function hasItem(key) {
  return G.inventory.some(e => e.key === key && e.qty > 0);
}

function addItem(key, qty) {
  const existing = G.inventory.find(e => e.key === key);
  const maxQ = ITEMS[key]?.max || 3;
  if (existing) {
    existing.qty = Math.min(maxQ, existing.qty + qty);
  } else {
    G.inventory.push({ key, qty: Math.min(maxQ, qty) });
  }
  renderInventory();
}

function removeItem(key, qty) {
  const existing = G.inventory.find(e => e.key === key);
  if (!existing) return;
  existing.qty -= qty;
  if (existing.qty <= 0) G.inventory = G.inventory.filter(e => e.key !== key);
  renderInventory();
}

function useItem(key) {
  if (!hasItem(key)) return;
  const item = ITEMS[key];
  if (!item) return;

  if (item.type === 'consumable') {
    if (key === 'agua')   { G.player.water = Math.min(100, G.player.water + 35); addSystem('+35 hidratación'); }
    if (key === 'comida'||key === 'bayas') { G.player.food = Math.min(100, G.player.food + 30); addSystem('+30 comida'); }
    if (key === 'vendaje') {
      G.player.health = Math.min(100, G.player.health + 20);
      removeStatus('intoxicacion');
      addSystem('+20 salud');
    }
    if (key === 'antidoto') {
      G.player.health = Math.min(100, G.player.health + 20);
      removeStatus('veneno'); removeStatus('infeccion'); removeStatus('picadura');
      addSystem('+20 salud, eliminados: veneno / infección / picadura');
    }
    if (key === 'pilas' && hasItem('linterna')) { addSystem('Linterna recargada'); }
    removeItem(key, 1);
    renderAll();
  } else if (item.type === 'lore') {
    addNarr(`<div class="narr-event"><div class="narr-event-title">${item.icon} ${item.name}</div><div class="narr-event-text">${item.effect}</div></div>`);
  } else {
    addNarr(`<div class="narr-system">// ${item.name}: ${item.effect}</div>`);
  }
}

// ═══════════════════════════════════════════════════════
//  LORE
// ═══════════════════════════════════════════════════════
function addLore(entry) {
  if (!G.lore.includes(entry)) {
    G.lore.push(entry);
    renderLorePanel();
  }
}

// ═══════════════════════════════════════════════════════
//  SCREENS
// ═══════════════════════════════════════════════════════
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
}

function showDeath() {
  document.getElementById('death-msg').textContent = G.deathMsg || 'Los Apalaches te reclamaron.';
  localStorage.removeItem('apalaches_save');
  showScreen('death');
}

function resetGame() {
  localStorage.removeItem('apalaches_save');
  showScreen('title');
}

function showMap() {
  addNarr(`<div class="narr-event">
    <div class="narr-event-title">🗺️ MAPA DE LA ZONA</div>
    <div class="narr-event-text">
      <pre style="font-size:0.75rem;line-height:1.8;color:var(--text-dim);font-family:'Inconsolata',monospace;">
  [CIMA NORTE]   ← luces vistas aquí
       |
  [BOSQUE DENSO] ← huellas anómalas
       |
  [TU REFUGIO] ← zona actual
     / \\
[ARROYO] [CLARO]
    |        |
[CUEVA]  [RUINAS]</pre>
    </div>
  </div>`);
}

function showDiario() {
  if (!G.lore.length) {
    addNarr('<div class="narr-system">// El diario está vacío. Explora para descubrir pistas.</div>');
    return;
  }
  let html = '<div class="narr-event"><div class="narr-event-title">📓 DIARIO DE CAMPO</div>';
  G.lore.forEach((l, i) => {
    html += `<div class="narr-event-text" style="margin-bottom:0.6rem;font-size:0.85rem;">
      <span style="color:var(--amber-dim);font-size:0.7rem;">ENTRADA ${i+1}:</span><br>${l}
    </div>`;
  });
  html += '</div>';
  addNarr(html);
}

function showCredits() {
  document.getElementById('screen-title').innerHTML += `
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.95);display:flex;align-items:center;justify-content:center;z-index:10;padding:2rem;" onclick="this.remove()">
      <div style="max-width:560px;font-family:'IM Fell English',serif;color:var(--text);font-size:0.95rem;line-height:1.8;">
        <div style="font-family:'Cinzel',serif;color:var(--amber);font-size:1.1rem;margin-bottom:1.2rem;">LORE DE LOS APALACHES</div>
        <p>Los Apalaches albergan una de las tradiciones de folklore más ricas de Norteamérica: criaturas cherokee como <em>Wampus Cat</em>, <em>Ew'ah</em> (espíritu de la locura) y <em>Spearfinger</em>.</p>
        <p style="margin-top:0.8rem;">Casos famosos: la <em>Bell Witch</em> de Tennessee, las <em>Luces de Brown Mountain</em> en Carolina del Norte, el <em>Mothman</em> de West Virginia.</p>
        <p style="margin-top:0.8rem;">Criaturas modernas: <em>Not Deer</em>, <em>Pale Crawler</em>, <em>Forest Mimic</em>. El bosque tiene memoria.</p>
        <p style="margin-top:1.2rem;color:var(--text-dim);font-size:0.8rem;">(Haz clic para cerrar)</p>
      </div>
    </div>
  `;
}

// ═══════════════════════════════════════════════════════
//  SAVE / LOAD
// ═══════════════════════════════════════════════════════
function saveGame(silent) {
  localStorage.setItem('apalaches_save', JSON.stringify(G));
  if (!silent) {
    const t = document.getElementById('save-toast');
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2000);
  }
}

// ═══════════════════════════════════════════════════════
//  UTILS
// ═══════════════════════════════════════════════════════
function shuffle(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

// ═══════════════════════════════════════════════════════
//  BOOT
// ═══════════════════════════════════════════════════════
init();
</script>
</body>
</html>
