    choices:[
      { text:'Responder. Quizás hay alguien en apuros.', outcome:'bad', delta:{sanity:-20,health:-15}, msg:'Te acercas. La voz se apaga. Al regresar al refugio, algo ha cambiado dentro. No sabes qué.' },
      { text:'Ignorarlo. Meterte más adentro del refugio.', outcome:'neutral', delta:{sanity:-5}, msg:'La voz cesa eventualmente. Pero esa noche sueñas con ella.' },
      { text:'Trazar una línea de sal en el umbral.', outcome:'good', delta:{sanity:8}, msg:'El susurro retrocede de inmediato. En la tradición local, la sal disuade a los imitadores.', requires:'sal' },
      { text:'Grabar con la grabadora para escucharlo mañana.', outcome:'neutral', delta:{sanity:-8}, msg:'Por la mañana escuchas la grabación. Tu voz responde sola en la cinta. No recuerdas haber hablado.', requires:'grabadora', lore:'Grabación anómala: la cinta registró una respuesta tuya que no recuerdas haber dado.' },
